# Copy to `.env` in the project root (or set variables in your host / Vercel dashboard).
# Loaded automatically by pydantic-settings when running the API.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=

# --- OpenAI ---
OPENAI_API_KEY=

# Optional: defaults used when a node omits `model` in the graph payload
DEFAULT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
DEFAULT_OPENAI_MODEL=gpt-4o-mini
