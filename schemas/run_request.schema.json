{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RunRequest",
  "type": "object",
  "required": ["sandbox_id", "graph", "prompt"],
  "properties": {
    "sandbox_id": { "type": "string" },
    "prompt": { "type": "string" },
    "graph": {
      "type": "object",
      "required": ["nodes", "edges", "collector", "global_context"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "role", "output_key", "output_type"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "role": { "type": "string" },
              "provider": { "enum": ["anthropic", "openai"] },
              "model": { "type": ["string", "null"] },
              "output_key": { "type": "string" },
              "output_type": { "enum": ["text", "json"] },
              "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
              "judge": {
                "type": ["object", "null"],
                "properties": {
                  "enabled": { "type": "boolean" },
                  "criteria": { "type": "string" },
                  "provider": { "enum": ["anthropic", "openai"] },
                  "model": { "type": ["string", "null"] },
                  "min_score": { "type": "number", "minimum": 0, "maximum": 1 },
                  "max_retries": { "type": "integer", "minimum": 0, "maximum": 10 }
                }
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target"],
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "source_field": { "type": ["string", "null"] },
              "target_field": { "type": ["string", "null"] }
            }
          }
        },
        "collector": {
          "type": "object",
          "required": ["id", "name", "kind"],
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "kind": { "const": "collector" }
          }
        },
        "global_context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
